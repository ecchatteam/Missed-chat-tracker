# Copy this file to .env and fill in your real connection string.
# Never commit the real .env file to GitHub — it contains your DB password.

# Get this from MongoDB Atlas: Database > Connect > Drivers > copy the connection string,
# then replace <password> with your actual database user password.
# Example:
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.xxxxx.mongodb.net/missed_chat_tracker?retryWrites=true&w=majority

MONGODB_URI=

# ── Auth ─────────────────────────────────────────────────────
# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Default admin account, created automatically the very first time the app
# connects to an empty database. Change the password after first login via
# POST /api/auth/change-password — these env vars are only used for that
# one-time seed, not read again afterwards.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Set automatically by Render/most hosts; only affects whether session
# cookies are marked "secure" (HTTPS-only). Leave unset for local dev.
# NODE_ENV=production

# Secret key that lets you reset the Admin password if forgotten, without
# needing the old password (via POST /api/auth/forgot-password from the
# login screen's "Forgot password?" link). Set this to any private string
# only you know — anyone with this key can reset the admin password, so
# treat it like a password itself. Leave unset to disable the feature.
ADMIN_RESET_KEY=
